{
  "name": "@kutti/cli",
  "version": "1.0.0",
  "description": "Kutti CLI - Your Personal AI CLI Agent",
  "main": "dist/index.js",
  "bin": {
    "kutti": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
